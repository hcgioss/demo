@model demo.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập - An Phát PC</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        /* Tạo hình nền Gradient phong cách công nghệ cực đẹp */
        body {
            background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .card-custom {
            border-radius: 15px;
            background-color: rgba(255, 255, 255, 0.95);
        }

        .input-custom {
            border-radius: 8px;
        }

        .btn-custom {
            border-radius: 8px;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card card-custom shadow-lg border-0">
                    <div class="card-body p-5">

                        <div class="text-center mb-4">
                            <h2 class="text-info font-weight-bold">🖥️ AN PHÁT PC</h2>
                            <p class="text-muted">Đăng nhập vào hệ thống quản trị</p>
                        </div>

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success shadow-sm font-weight-bold text-center">@TempData["Success"]</div>
                        }
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger shadow-sm font-weight-bold text-center">@ViewBag.Error</div>
                        }

                        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                        {
                            <div class="form-group mb-3">
                                <label class="font-weight-bold text-secondary">Tên đăng nhập</label>
                                @Html.TextBoxFor(m => m.Username, new { @class = "form-control form-control-lg input-custom", placeholder = "Nhập tài khoản..." })
                                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
                            </div>
                            <div class="form-group mb-4">
                                <label class="font-weight-bold text-secondary">Mật khẩu</label>
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg input-custom", placeholder = "Nhập mật khẩu..." })
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                            </div>

                            <button type="submit" class="btn btn-info btn-lg btn-block btn-custom font-weight-bold shadow-sm">
                                ĐĂNG NHẬP
                            </button>
                        }

                        <div class="mt-4 text-center">
                            <span class="text-muted">Chưa có tài khoản nhân viên?</span>
                            <a href="/Account/Register" class="font-weight-bold text-info text-decoration-none">Đăng ký mới</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>