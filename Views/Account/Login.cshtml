@model demo.Models.LoginViewModel

@{
    ViewBag.Title = "Đăng nhập - An Phát Computer";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e2937 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            max-width: 420px;
            width: 100%;
        }

        .login-header {
            background: linear-gradient(90deg, #1e40af, #3b82f6);
            color: white;
            padding: 2rem 1.5rem;
            text-align: center;
        }

            .login-header h2 {
                margin: 0;
                font-weight: 700;
            }

        .login-body {
            padding: 2rem 2.5rem;
        }

        .form-control {
            border-radius: 10px;
            padding: 12px 16px;
            border: 1px solid #cbd5e1;
        }

            .form-control:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            }

        .btn-login {
            background: linear-gradient(90deg, #1e40af, #3b82f6);
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(59, 130, 246, 0.4);
            }

        .alert {
            border-radius: 10px;
        }

        .info-box {
            background: #f8fafc;
            border-left: 4px solid #3b82f6;
            padding: 12px 16px;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <!-- Header -->
        <div class="login-header">
            <h2>An Phát Computer</h2>
            <p class="mb-0 mt-2 opacity-90">Hệ thống quản lý kinh doanh linh kiện máy tính</p>
        </div>

        <!-- Body -->
        <div class="login-body">
            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "" }))
            {
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    @Html.LabelFor(m => m.Username, "Tên đăng nhập", new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Nhập tên đăng nhập" })
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-4">
                    @Html.LabelFor(m => m.Password, "Mật khẩu", new { @class = "form-label fw-semibold" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                </div>

                if (!string.IsNullOrEmpty(Model?.ErrorMessage))
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
                    </div>
                }

                <button type="submit" class="btn btn-primary btn-login w-100 text-white">
                    <i class="fas fa-sign-in-alt me-2"></i> Đăng nhập
                </button>
            }

            <!-- Thông tin tài khoản thử nghiệm -->
            <div class="info-box mt-4">
                <small class="text-muted">
                    <strong>Tài khoản Admin thử nghiệm:</strong><br>
                    <i class="fas fa-user me-1"></i> <strong>admin</strong><br>
                    <i class="fas fa-lock me-1"></i> <strong>Admin@123</strong>
                </small>
            </div>
        </div>

        <!-- Footer -->
        <div class="text-center py-3 border-top bg-light">
            <small class="text-muted">© 2026 An Phát Computer - All Rights Reserved</small>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>