@model demo.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Đăng ký tài khoản - An Phát PC</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); /* Nền xanh dương chuyên nghiệp */
            min-height: 100vh;
            display: flex;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px 0;
        }

        .card-custom {
            border-radius: 15px;
            background-color: rgba(255, 255, 255, 0.95);
        }

        .input-custom {
            border-radius: 8px;
        }

        .btn-custom {
            border-radius: 8px;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card card-custom shadow-lg border-0">
                    <div class="card-body p-5">

                        <div class="text-center mb-4">
                            <h2 class="text-primary font-weight-bold">TẠO TÀI KHOẢN MỚI</h2>
                            <p class="text-muted">Điền thông tin để tham gia hệ thống An Phát PC</p>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger shadow-sm font-weight-bold text-center">@ViewBag.Error</div>
                        }

                        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                        {
                            <div class="form-row">
                                <div class="form-group col-md-6 mb-3">
                                    <label class="font-weight-bold text-secondary">Tên đăng nhập</label>
                                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control form-control-lg input-custom", placeholder = "VD: admin123" })
                                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
                                </div>
                                <div class="form-group col-md-6 mb-3">
                                    <label class="font-weight-bold text-secondary">Mật khẩu</label>
                                    @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-lg input-custom", placeholder = "Mật khẩu..." })
                                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label class="font-weight-bold text-secondary">Họ và tên nhân viên</label>
                                @Html.TextBoxFor(m => m.FullName, new { @class = "form-control form-control-lg input-custom", placeholder = "Nhập đầy đủ họ tên..." })
                                @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group mb-4">
                                <label class="font-weight-bold text-secondary">Số điện thoại liên hệ</label>
                                @Html.TextBoxFor(m => m.Phone, new { @class = "form-control form-control-lg input-custom", placeholder = "09xx xxx xxx" })
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg btn-block btn-custom font-weight-bold shadow-sm">
                                HOÀN TẤT ĐĂNG KÝ
                            </button>
                        }

                        <div class="mt-4 text-center">
                            <span class="text-muted">Đã có tài khoản?</span>
                            <a href="/Account/Login" class="font-weight-bold text-primary text-decoration-none">Đăng nhập ngay</a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>