@model IEnumerable<demo.Models.Product>
@{
    Layout = null; // Dòng này giúp ngắt cái giao diện xấu mặc định đi
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý danh mục linh kiện</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="text-primary mb-0">Danh mục linh kiện máy tính</h2>
                <a href="/Product/Create" class="btn btn-primary font-weight-bold">+ Thêm linh kiện mới</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="thead-dark">
                        <tr>
                            <th>Tên sản phẩm</th>
                            <th>Phân loại</th>
                            <th>Giá niêm yết</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle font-weight-bold">@item.ProductName</td>
                                <td class="align-middle"><span class="badge badge-info px-2 py-1">@item.Category</span></td>
                                <td class="align-middle text-danger font-weight-bold">@item.Price.ToString("N0") đ</td>
                                <td class="align-middle text-center">
                                    <a href="/Product/Edit/@item.ProductId" class="btn btn-sm btn-warning">Sửa</a>
                                    <a href="/Product/Delete/@item.ProductId" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa linh kiện này?')">Xóa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="mt-3">
            <a href="/Home/Index" class="btn btn-secondary">&larr; Quay lại Bảng điều khiển</a>
        </div>
    </div>
</body>
</html>