@model demo.Models.ProductItem
@{
    Layout = null; // Ngắt khung giao diện mặc định cũ
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý Nhập Kho</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow border-primary">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0 text-center font-weight-bold">📦 QUÉT MÃ SERIAL NHẬP KHO</h4>
                    </div>
                    <div class="card-body p-4">

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success shadow-sm">@TempData["SuccessMessage"]</div>
                        }
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger shadow-sm">@TempData["ErrorMessage"]</div>
                        }

                        @using (Html.BeginForm("AddSerial", "Inventory", FormMethod.Post))
                        {
                            <div class="form-group mb-4">
                                <label class="font-weight-bold">1. Chọn linh kiện</label>

                                @Html.DropDownListFor(m => m.ProductId, ViewBag.ProductList as SelectList, "-- Chọn linh kiện từ danh mục --", new { @class = "form-control form-control-lg" })

                                @Html.ValidationMessageFor(m => m.ProductId, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group mb-4">
                                <label class="font-weight-bold">2. Mã Serial / Barcode</label>
                                @Html.TextBoxFor(m => m.SerialNumber, new { @class = "form-control form-control-lg", placeholder = "Quét hoặc nhập mã vạch vào đây..." })
                                @Html.ValidationMessageFor(m => m.SerialNumber, "", new { @class = "text-danger" })
                            </div>

                            <button type="submit" class="btn btn-primary btn-block btn-lg font-weight-bold shadow mt-3">Xác nhận nhập kho</button>
                        }
                    </div>

                    <div class="card-footer bg-white text-center py-3">
                        <a href="/Home/Index" class="text-secondary font-weight-bold text-decoration-none">
                            &larr; Quay lại Bảng điều khiển
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>