@model demo.Models.ProductItem

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Quản lý Nhập Kho</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body class="container mt-5">
    <h2 class="text-primary">Nhập linh kiện vào kho</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-md-6">
            @using (Html.BeginForm("AddSerial", "Inventory", FormMethod.Post))
            {
                <div class="form-group mb-3">
                    <label class="font-weight-bold">Chọn linh kiện</label>
                    @Html.DropDownListFor(m => m.ProductId, new SelectList(new[]
                    {
                        new { ID = 1, Name = "CPU Intel Core i5 13400F" },
                        new { ID = 2, Name = "Mainboard ASUS B760M" },
                        new { ID = 3, Name = "RAM Corsair Vengeance 16GB" }
                    }, "ID", "Name"), "-- Chọn linh kiện --", new { @class = "form-control" })

                    @Html.ValidationMessageFor(m => m.ProductId, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mb-3">
                    <label class="font-weight-bold">Mã Serial / Barcode</label>
                    @Html.TextBoxFor(m => m.SerialNumber, new { @class = "form-control", placeholder = "Quét hoặc nhập mã vạch vào đây..." })

                    @Html.ValidationMessageFor(m => m.SerialNumber, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn btn-primary mt-3">Thêm vào kho</button>
            }
        </div>
    </div>
</body>
</html>