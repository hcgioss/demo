@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Xuất kho linh kiện</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow border-danger">
                    <div class="card-header bg-danger text-white">
                        <h4 class="mb-0 text-center font-weight-bold">📤 QUÉT MÃ SERIAL XUẤT KHO</h4>
                    </div>
                    <div class="card-body p-4">

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success shadow-sm font-weight-bold">@TempData["SuccessMessage"]</div>
                        }
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger shadow-sm font-weight-bold">@TempData["ErrorMessage"]</div>
                        }

                        @using (Html.BeginForm("Export", "Inventory", FormMethod.Post))
                        {
                            <div class="form-group mb-4">
                                <label class="font-weight-bold">Quét mã Serial / Barcode linh kiện cần xuất:</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white text-danger">🔍</span>
                                    </div>
                                    <input type="text" name="serialNumber" class="form-control form-control-lg border-danger" placeholder="Quét mã vạch vào đây..." required autofocus />
                                </div>
                                <small class="text-muted mt-2 d-block">Hệ thống sẽ kiểm tra và trừ tồn kho tự động.</small>
                            </div>

                            <button type="submit" class="btn btn-danger btn-block btn-lg font-weight-bold shadow mt-3">XÁC NHẬN XUẤT KHO</button>
                        }
                    </div>

                    <div class="card-footer bg-white text-center py-3">
                        <a href="/Home/Index" class="text-secondary font-weight-bold text-decoration-none">
                            &larr; Quay lại Bảng điều khiển
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>