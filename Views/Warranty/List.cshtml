@model List<demo.Models.WarrantyTicketViewModel>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Danh sách Phiếu Bảo Hành - An Phát Computer</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .main-card {
            max-width: 1100px;
            margin: 30px auto;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            border-radius: 12px;
        }
        .table th {
            background-color: #f1f3f5;
        }
    </style>
</head>
<body>
    <div class="main-card card">
        <div class="card-header bg-info text-white py-3">
            <h3 class="mb-0 text-center">
                <i class="glyphicon glyphicon-list-alt"></i> 
                Danh sách Phiếu Bảo Hành
            </h3>
        </div>
        <div class="card-body p-4">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            @if (Model == null || Model.Count == 0)
            {
                <div class="alert alert-info text-center py-5">
                    <h5>Chưa có phiếu bảo hành nào được lập</h5>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th>Ticket ID</th>
                                <th>Serial Number</th>
                                <th>SĐT Khách</th>
                                <th>Mô tả lỗi</th>
                                <th>Trạng thái</th>
                                <th>Ngày nhận</th>
                                <th>Ngày trả</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>#@item.TicketId</strong></td>
                                    <td>@item.SerialNumber</td>
                                    <td>@item.CustomerPhone</td>
                                    <td>@item.IssueDescription</td>
                                    <td>
                                        <span class="badge @(item.TicketStatus.Contains("Hoàn thành") ? "badge-success" : "badge-warning")">
                                            @item.TicketStatus
                                        </span>
                                    </td>
                                    <td>@item.ReceiveDate.ToString("dd/MM/yyyy")</td>
                                    <td>@(item.ReturnDate?.ToString("dd/MM/yyyy") ?? "Chưa trả")</td>
                                    <td>
                                        @using (Html.BeginForm("UpdateStatus", "Warranty2", FormMethod.Post))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ticketId" value="@item.TicketId" />
                                            <select name="newStatus" class="form-control form-control-sm d-inline w-auto">
                                                <option value="Đang xử lý">Đang xử lý</option>
                                                <option value="Đang sửa chữa">Đang sửa chữa</option>
                                                <option value="Chờ linh kiện">Chờ linh kiện</option>
                                                <option value="Hoàn thành">Hoàn thành</option>
                                                <option value="Đã trả máy">Đã trả máy</option>
                                            </select>
                                            <button type="submit" class="btn btn-primary btn-sm">Cập nhật</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Warranty")" class="btn btn-secondary btn-lg">← Quay lại Tra cứu</a>
                <a href="@Url.Action("Create", "Warranty2")" class="btn btn-success btn-lg">+ Lập phiếu mới</a>
            </div>
        </div>
    </div>
</body>
</html>